# Convex
CONVEX_DEPLOYMENT=your-team:your-project
VITE_CONVEX_URL=https://your-production-deployment.convex.cloud

# WorkOS AuthKit
WORKOS_CLIENT_ID=client_your_workos_client_id
WORKOS_API_KEY=sk_your_workos_api_key
WORKOS_REDIRECT_URI=http://localhost:3000/callback
WORKOS_COOKIE_PASSWORD=generate_a_random_secret_with_at_least_32_characters

# Ekorn access control
ALLOWED_USER_EMAILS=you@example.com

# Receipt OCR
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
OCR_PROVIDER=openai
